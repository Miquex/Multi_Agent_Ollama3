# ── Virtual environments ─────────────────────────────────────────────
.venv/
venv/
env/

# ── Git ──────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Python caches ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
